# ============================================================
# AutoShkolla Platform — Frontend Environment
# ============================================================

# Public URL of the backend API. Must include the /api/v1 suffix.
# Local development:
NEXT_PUBLIC_API_URL=http://localhost:5002/api/v1
# Production (set in Vercel project settings):
# NEXT_PUBLIC_API_URL=https://api.autoshkolla-platform.com/api/v1

# Optional: used by the dev-only Next.js rewrite in next.config.js.
# Leave unset to use the default http://localhost:5002.
# API_PROXY_TARGET=http://localhost:5002
